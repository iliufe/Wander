# Wander single-service backend
# Local development port. Most hosting platforms inject PORT automatically.
WANDER_API_PORT=8788

# Qwen / DashScope OpenAI-compatible endpoint
# Official docs:
# https://help.aliyun.com/zh/model-studio/compatibility-of-openai-with-dashscope
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_INTENT_MODEL=qwen-plus

# AMap / Gaode Web Service key for reverse geocoding, POI search, weather, and route legs
AMAP_WEB_SERVICE_KEY=

# AMap JavaScript map key for frontend map rendering
VITE_AMAP_JS_KEY=
VITE_AMAP_SECURITY_JSCODE=

# Optional password gate for internal testing deployments.
# Leave both empty locally if you do not want the browser password prompt.
WANDER_BASIC_AUTH_USER=
WANDER_BASIC_AUTH_PASSWORD=
